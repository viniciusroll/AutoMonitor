# =====================================================================
# Vehicle Monitor - Variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores reais.
#   cp .env.example .env
# =====================================================================

# --- Banco de dados ---
# URL no formato SQLAlchemy. Por padrão usa um arquivo SQLite local.
DATABASE_URL=sqlite:///vehicle_monitor.db

# --- Playwright ---
# HEADLESS=true roda o navegador sem interface (produção).
# HEADLESS=false abre o navegador (útil para depuração).
HEADLESS=true

# Quantidade máxima de anúncios coletados por busca (por provider).
MAX_RESULTS=100

# Timeout padrão de navegação (ms).
NAVIGATION_TIMEOUT=30000

# --- Notificações: Telegram ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notificações: Discord ---
DISCORD_WEBHOOK=

# --- Notificações: Email (SMTP) ---
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_TO=

# --- Logs ---
# Nível: TRACE, DEBUG, INFO, SUCCESS, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
